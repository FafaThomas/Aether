<Page
    x:Class="Aether_UI.MovieDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>

        <StackPanel>

            <Image
                x:Name="BackdropImage"
                Height="400"
                Stretch="UniformToFill"/>

            <StackPanel Padding="20">

                <TextBlock
                    x:Name="TitleText"
                    FontSize="32"
                    FontWeight="Bold"/>

                <TextBlock
                    x:Name="RatingText"
                    Margin="0,10,0,0"/>

                <TextBlock
                    x:Name="OverviewText"
                    Margin="0,20,0,0"
                    TextWrapping="Wrap"/>

                <Button
                    Content="Play"
                    Margin="0,30,0,0"
                    Click="PlayButton_Click"/>

            </StackPanel>

        </StackPanel>

    </ScrollViewer>

</Page>