<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Aether_UI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>

        <StackPanel Padding="20" Spacing="20">

            <TextBlock
                Text="Popular Movies"
                FontSize="32"
                FontWeight="Bold"/>

            <GridView
                x:Name="MoviesGrid"
                IsItemClickEnabled="True"
                ItemClick="MoviesGrid_ItemClick">
                
                <GridView.ItemTemplate>
                    <DataTemplate>

                        <StackPanel Width="180">

                            <Image
                                Width="180"
                                Height="270"
                                Stretch="UniformToFill"
                                Source="{Binding PosterUrl}"/>

                            <TextBlock
                                Text="{Binding Title}"
                                TextWrapping="WrapWholeWords"/>

                            <TextBlock
                                Text="{Binding VoteAverage}"/>

                        </StackPanel>

                    </DataTemplate>
                </GridView.ItemTemplate>

            </GridView>

        </StackPanel>

    </ScrollViewer>

</Page>
